# JIFAS AI Assistant - Production Environment Configuration
# This file contains actual deployment values

# Database Connection (Local SQL Server)
# Using localdb with Windows Authentication
ConnectionStrings__DefaultConnection=Data Source=(localdb)\MSSQLLocalDB;Database=JIFAS_Assistant;Integrated Security=True;Persist Security Info=False;Pooling=False;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Application Name=JifasAssistant;Command Timeout=0

# Gemini API Configuration
Gemini__ApiKey=AIzaSyDdTDJEIjXTPI4IoJLTTP4giavhvkR8z0k
Gemini__Model=gemini-2.0-flash
Gemini__BaseUrl=https://generativelanguage.googleapis.com/v1beta/models

# Application Environment
ASPNETCORE_ENVIRONMENT=Production

# Logging
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft=Warning

# Caching
Caching__EnableResponseCache=true
Caching__ResponseCacheDurationHours=24

# Port Configuration
ASPNETCORE_URLS=http://+:8888
