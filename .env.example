# JIFAS AI Assistant - Environment Configuration Template
# Salin ke .env lalu isi nilai rahasia sesuai environment.

# ========================================
# DATABASE CONFIGURATION
# ========================================
# PostgreSQL + pgvector di Docker.
POSTGRES_DB=jifas_assistant
POSTGRES_USER=jifas
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_PORT=5432
ConnectionStrings__DefaultConnection=Host=jifas-postgres;Port=5432;Database=jifas_assistant;Username=jifas;Password=replace-with-a-strong-password
REDIS_PORT=6379
ConnectionStrings__Redis=jifas-redis:6379

# ========================================
# SECURITY
# ========================================
# Wajib untuk endpoint admin KB jika role admin JWT tidak dipakai.
Admin__ApiKey=replace-with-a-long-random-secret

# Opsional: batasi CORS ke origin frontend JIFAS.
Cors__AllowedOrigins__0=https://jifas.example.com

# Validasi JWT. Gunakan Authority (JWKS/OIDC) atau SigningKey yang kuat.
Jwt__Enabled=true
Jwt__Authority=
Jwt__Audience=JifasWebApp
Jwt__SigningKey=

# ========================================
# OLLAMA AI CONFIGURATION
# ========================================
# Ollama berjalan di server lokal 10.0.12.54:11434
# Ollama tidak butuh API key, jadi biarkan kosong.
Embedding__TimeoutSeconds=90

# ========================================
# APPLICATION ENVIRONMENT
# ========================================
# Pilihan: Development, Staging, Production.
ASPNETCORE_ENVIRONMENT=Production

# Request logging lama dimatikan default karena Docker sudah punya log stdout.
Logging__EnableRequestLogging=false

# Docker lokal berjalan lewat HTTP port 8888, jadi HTTPS redirect dimatikan.
Https__EnableRedirection=false

# ========================================
# CACHING
# ========================================
# Redis dipakai untuk cache jawaban, suggestion, query expansion, dan session.
Caching__UseRedis=true
Caching__RedisInstanceName=JIFAS:
Caching__EnableResponseCache=true
Caching__ResponseCacheDurationHours=24
Caching__EnableKBCache=true

# ========================================
# JIRA TICKET INTEGRATION
# ========================================
Jira__BaseUrl=https://willyjan.atlassian.net
Jira__ProjectKey=JTU
Jira__CloudId=
Jira__ApiToken=replace-with-jira-token
Jira__AccountEmail=magang.it@jababeka.com
Jira__EmailDomain=jababeka.com
Jira__DefaultIssueType=Task
Jira__TimeoutSeconds=30
Jira__EnableOfflineFallback=false
# Aktifkan hanya jika CA kantor belum tersedia di container.
Jira__BypassSslValidation=false

# ========================================
# DOCKER COMPOSE SETTINGS
# ========================================
# Nama project Docker Compose (opsional).
COMPOSE_PROJECT_NAME=jifas-ai-assistant

