# JIFAS AI Assistant - Environment Configuration Template
# Copy this to .env and fill in your actual values

# ========================================
# DATABASE CONFIGURATION
# ========================================
# Connection string for external SQL Server (NOT in Docker)
# Format: Server=<hostname_or_ip>,<port>;Database=<database>;User Id=<username>;Password=<password>;TrustServerCertificate=true;
DB_CONNECTION_STRING=Server=192.168.1.100,1433;Database=JIFAS_Assistant;User Id=sa;Password=YourStrongPassword123!;TrustServerCertificate=true;
ConnectionStrings__DefaultConnection=Server=192.168.1.100,1433;Database=JIFAS_Assistant;User Id=sa;Password=YourStrongPassword123!;TrustServerCertificate=true;

# ========================================
# SECURITY
# ========================================
# Required for KB admin endpoints when JWT admin role is not used.
Admin__ApiKey=replace-with-a-long-random-secret

# Optional: lock CORS to your JIFAS frontend origin.
Cors__AllowedOrigins__0=https://jifas.example.com

# JWT validation. Use either Authority (JWKS/OIDC) or a strong SigningKey.
Jwt__Enabled=true
Jwt__Authority=
Jwt__Audience=JifasWebApp
Jwt__SigningKey=

# ========================================
# OLLAMA AI CONFIGURATION
# ========================================
# Ollama berjalan di server lokal 10.0.12.54:11434
# Ollama tidak butuh API key - set ke string kosong atau hapus

# ========================================
# APPLICATION ENVIRONMENT
# ========================================
# Options: Development, Staging, Production
ASPNETCORE_ENVIRONMENT=Production

# ========================================
# DOCKER COMPOSE SETTINGS
# ========================================
# Compose project name (optional)
COMPOSE_PROJECT_NAME=jifas-ai-assistant

