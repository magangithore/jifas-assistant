# ========================================
# Docker Environment Configuration
# ========================================
# Copy values from .env.example and update with your actual values

# ========== GEMINI API CONFIGURATION ==========
Gemini__ApiKey=your-gemini-api-key-here
Gemini__Model=gemini-2.0-flash
Gemini__BaseUrl=https://generativelanguage.googleapis.com/v1beta/models

# ========== DATABASE CONNECTION ==========
# For Docker: Use connection string that works within container
# For SQL Server in Docker: replace Server=(localdb)\\MSSQLLocalDB with your server
ConnectionStrings__DefaultConnection=Server=(localdb)\\MSSQLLocalDB;Database=JIFAS_Assistant;Integrated Security=true;Encrypt=false;TrustServerCertificate=true

# ========== ASP.NET CORE ==========
ASPNETCORE_ENVIRONMENT=Production

# ========== LOGGING ==========
Logging__LogLevel__Default=Information

# ========== CACHING ==========
Caching__EnableResponseCache=true
Caching__ResponseCacheDurationHours=24
Caching__EnableKBCache=true
