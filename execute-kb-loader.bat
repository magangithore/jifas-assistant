@echo off
REM ???????????????????????????????????????????????????????????????????????????
REM JIFAS Knowledge Base Loader - Full Automated Execution
REM Author: Copilot
REM Status: Production Ready
REM ???????????????????????????????????????????????????????????????????????????

setlocal enabledelayedexpansion

color 0B
cls

echo.
echo ?????????????????????????????????????????????????????????????????????
echo ?                                                                   ?
echo ?     JIFAS Knowledge Base Loader - Full Automated Execution        ?
echo ?                                                                   ?
echo ?     Status: Production Ready                                     ?
echo ?     Version: 2.0                                                 ?
echo ?     Expected: 52 files ^> 456+ chunks ^> SQL Server               ?
echo ?                                                                   ?
echo ?????????????????????????????????????????????????????????????????????
echo.

REM ???????????????????????????????????????????????????????????????????????????
REM STEP 1: Verify Prerequisites
REM ???????????????????????????????????????????????????????????????????????????

echo STEP 1: Verifying Prerequisites...
echo ???????????????????????????????????????????????????????????????????
echo.

echo [1/4] Checking project structure...

if not exist "KBLoader" (
    echo  X Missing: KBLoader
    goto error
)
echo  OK KBLoader

if not exist "Jifas.Assistant" (
    echo  X Missing: Jifas.Assistant
    goto error
)
echo  OK Jifas.Assistant

if not exist "Jifas.Assistant\KnowledgeBase" (
    echo  X Missing: Jifas.Assistant\KnowledgeBase
    goto error
)
echo  OK Jifas.Assistant\KnowledgeBase

if not exist "jifas_assistant.DAL" (
    echo  X Missing: jifas_assistant.DAL
    goto error
)
echo  OK jifas_assistant.DAL

echo.

echo [2/4] Checking .NET SDK...
dotnet --version >nul 2>&1
if errorlevel 1 (
    echo  X .NET SDK not found
    goto error
)
echo  OK .NET SDK found
dotnet --version

echo.

echo [3/4] Checking SQL Server...
echo SQL Server check requires manual verification
echo  - Ensure SQL Server is running
echo  - Verify database JIFAS_Assistant exists
echo.

echo [4/4] Checking Ollama...
echo Ollama check requires manual verification
echo  - Ensure Ollama is running: ollama serve
echo  - Verify endpoint: http://10.0.12.54:11434
echo  - Verify model pulled: ollama pull qwen3-embedding:4b
echo.

echo OK Prerequisites check complete
echo.

REM ???????????????????????????????????????????????????????????????????????????
REM STEP 2: Build Project
REM ???????????????????????????????????????????????????????????????????????????

echo STEP 2: Building KBLoader project...
echo ???????????????????????????????????????????????????????????????????
echo.

cd KBLoader

echo Building KBLoader...
dotnet build --configuration Release

if errorlevel 1 (
    echo.
    echo X Build failed
    cd ..
    goto error
)

echo.
echo OK Build successful
echo.
cd ..

REM ???????????????????????????????????????????????????????????????????????????
REM STEP 3: User Confirmation
REM ???????????????????????????????????????????????????????????????????????????

echo STEP 3: Ready to load Knowledge Base
echo ???????????????????????????????????????????????????????????????????
echo.
echo This will:
echo   1. Clear existing KB documents from database
echo   2. Scan 52 KB files from KnowledgeBase/
echo   3. Split into ~456 chunks (paragraph-based)
echo   4. Generate embeddings via Ollama (1024-dimensional)
echo   5. Insert all chunks into SQL Server
echo.
echo Expected time: ~23 minutes
echo.

set /p confirm="Continue with KB loading? (Y/N): "

if /i not "%confirm%"=="Y" (
    echo Operation cancelled by user
    exit /b 0
)

echo.

REM ???????????????????????????????????????????????????????????????????????????
REM STEP 4: Run KB Loader
REM ???????????????????????????????????????????????????????????????????????????

echo STEP 4: Running KB Loader...
echo ???????????????????????????????????????????????????????????????????
echo.

cd KBLoader

echo Executing: dotnet run --configuration Release
echo.

dotnet run --configuration Release

if errorlevel 1 (
    echo.
    echo X KB Loader execution failed
    cd ..
    goto error
)

cd ..

echo.

REM ???????????????????????????????????????????????????????????????????????????
REM Final Summary
REM ???????????????????????????????????????????????????????????????????????????

echo.
echo ?????????????????????????????????????????????????????????????????????
echo ?                                                                   ?
echo ?              OK KNOWLEDGE BASE LOADED SUCCESSFULLY                ?
echo ?                                                                   ?
echo ?  Status: Ready for RAG queries                                   ?
echo ?  Next: Start API and test chat endpoint                          ?
echo ?                                                                   ?
echo ?????????????????????????????????????????????????????????????????????
echo.

echo Next steps:
echo   1. Verify in database: SELECT TOP 10 * FROM KnowledgeBaseDocuments
echo   2. Start API: dotnet run (from Jifas.Assistant/)
echo   3. Test RAG: Send chat query to API
echo.

pause
exit /b 0

:error
color 0C
echo.
echo X ERROR: Prerequisites check failed
echo.
pause
exit /b 1
