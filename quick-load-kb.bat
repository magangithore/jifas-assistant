REM ???????????????????????????????????????????????????????????????????????????

color 0B
cls

echo.
echo ?????????????????????????????????????????????????????????????????????????
echo ?                                                                       ?
echo ?     JIFAS Knowledge Base Loader - Running in Background              ?
echo ?                                                                       ?
