    color 0A
    echo.
    echo ? Knowledge Base loading COMPLETED
    echo.
    echo Check database: SELECT COUNT(*) FROM KnowledgeBaseDocuments
    echo.
    pause
) else (
    color 0C
    echo.
    echo ? Knowledge Base loading FAILED
    echo.
    echo Check error messages above
    echo.
    pause
)

exit /b

