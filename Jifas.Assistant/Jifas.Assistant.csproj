    <Compile Remove="Services\ConversationService.cs" />
    <Compile Remove="Services\AnalyticsService.cs" />
    <Compile Remove="Services\TicketService.cs" />
    <Compile Remove="Services\HealthCheckService.cs" />
    <Compile Remove="Services\ChatService.cs" />
    <Compile Remove="Services\IQdrantSeedingService.cs" />
    <Compile Remove="Services\SuggestionService.cs" />
    <Compile Remove="Services\GeminiEmbeddingService.cs" />
    <Compile Remove="Services\FileLoggerService.cs" />
    <Compile Remove="Services\QdrantVectorService.cs" />
    <Compile Remove="Services\EmbeddingService.cs" />
    <Compile Remove="Services\MetricsService.cs" />
    <Compile Remove="Services\GeminiService.cs" />
    <Compile Remove="Services\CommonQueryCacheService.cs" />
    <Compile Remove="Services\OutOfScopeDetector.cs" />
