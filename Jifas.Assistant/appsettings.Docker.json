{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    },
    "EnableRequestLogging": false,
    "MinLevel": "Information",
    "LogFilePath": "/app/Logs/jifas-chatbot-{Date}.log"
  },

  "AllowedHosts": "*",

  "Https": {
    "EnableRedirection": false
  },

  "ConnectionStrings": {
    "DefaultConnection": "Host=jifas-postgres;Port=5432;Database=jifas_assistant;Username=jifas;Password=jifas_dev_password",
    "Redis": "jifas-redis:6379"
  },

  "Cors": {
    "AllowedOrigins": []
  },

  "Admin": {
    "ApiKey": ""
  },

  "Jwt": {
    "Enabled": true,
    "Audience": "JifasWebApp",
    "Authority": "",
    "SigningKey": "",
    "ValidateIssuer": true,
    "ValidateAudience": true,
    "ValidateLifetime": true,
    "ClockSkewSeconds": 30,
    "RequireHttpsMetadata": false
  },

  "Ollama": {
    "BaseUrl": "http://10.0.12.54:11434",
    "Model": "qwen3:8b",
    "Temperature": 0.3,
    "MaxTokens": 2048,
    "TimeoutSeconds": 180
  },

  "Embedding": {
    "Provider": "Ollama",
    "Model": "qwen3-embedding:4b",
    "OllamaUrl": "http://10.0.12.54:11434",
    "Dimensions": 2560,
    "TimeoutSeconds": 90
  },

  "Support": {
    "HelpDeskEmail": "it@jababeka.com",
    "HelpDeskPhone": "+62-21-5241-8000",
    "Department": "IT Help Desk"
  },

  "Suggestion": {
    "MaxSuggestions": 3,
    "MinLength": 5,
    "MaxLength": 200,
    "EnableCaching": true,
    "CacheDurationMinutes": 30
  },

  "KnowledgeBase": {
    "CacheDurationMinutes": 30,
    "MaxDocumentsPerSearch": 3,
    "MinRelevanceScore": 0.3,
    "UseQdrant": false,
    "QdrantTopK": 5,
    "MinConfidenceScore": 0.5,
    "TopKResults": 3
  },

  "Chat": {
    "DefaultErrorMessage": "Mohon maaf, terjadi kesalahan dalam memproses pertanyaan Anda. Silakan coba lagi atau hubungi {SupportDept} di {SupportEmail}.",
    "EmptyMessageError": "Mohon maaf, pesan Anda kosong. Silakan ajukan pertanyaan tentang JIFAS.",
    "NoKBMatchMessage": "Mohon maaf, saya tidak menemukan informasi yang relevan di Knowledge Base JIFAS untuk pertanyaan Anda. Silakan coba dengan kata kunci lain atau hubungi {SupportDept} di {SupportEmail}.",
    "OutOfScopeMessage": "Mohon maaf, pertanyaan Anda berada di luar cakupan JIFAS AI Assistant. Saya dirancang khusus untuk menjawab pertanyaan tentang JIFAS (Jababeka Integrated Finance Accounting System) saja, seperti akses login, troubleshooting, penggunaan modul AR/AP/GL, dan fitur-fitur JIFAS lainnya. Apakah ada pertanyaan lain tentang JIFAS yang bisa saya bantu?"
  },

  "Caching": {
    "UseRedis": true,
    "RedisInstanceName": "JIFAS:",
    "DefaultDurationMinutes": 30,
    "ResponseDurationHours": 24,
    "EnableKBCache": true,
    "EnableResponseCache": true,
    "KBDocumentCacheDurationMinutes": 60,
    "KBSearchCacheDurationMinutes": 30,
    "ResponseCacheDurationHours": 24
  },

  "API": {
    "RequestTimeout": 30000,
    "MaxRequestBodySize": 5242880
  },

  "Qdrant": {
    "Enabled": false,
    "Note": "PostgreSQL pgvector semantic search is active; Qdrant package is not wired into runtime search."
  },

  "Search": {
    "UseQdrant": false,
    "QdrantTopK": 5
  },

  "Metrics": {
    "EnableTracking": true,
    "TrackSuggestionDisplay": true,
    "TrackSuggestionClick": true,
    "TrackUserFeedback": true,
    "CacheDurationMinutes": 1440
  },

  "HealthCheck": {
    "EnableDetailedStatus": true,
    "CheckInterval": 30
  },

  "Performance": {
    "EnableMonitoring": true,
    "SlowOperationThresholdMs": 1000,
    "MaxCacheSize": 10000,
    "EnableCompressionResponse": true,
    "CompressionThresholdBytes": 1024
  },

  "Optimization": {
    "EnableOption1ExpandedCache": true
  },

  "Jira": {
    "EnableOfflineFallback": false,
    "BypassSslValidation": false
  },

  "AiLearning": {
    "Enabled": true,
    "CollectorIntervalMinutes": 10,
    "PublisherIntervalMinutes": 15,
    "MaxPublishPerRun": 10
  }
}

