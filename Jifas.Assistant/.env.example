# ========================================
# JIFAS AI Assistant - Environment Variables
# ========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env file to version control!

# ========== GEMINI API CONFIGURATION ==========
GEMINI__APIKEY=your-gemini-api-key-here
GEMINI__MODEL=gemini-2.0-flash
GEMINI__BASEURL=https://generativelanguage.googleapis.com/v1beta/models

# ========== OPENAI API CONFIGURATION (Optional) ==========
OPENAI__APIKEY=sk-proj-your-openai-api-key-here

# ========== AZURE OPENAI CONFIGURATION (Optional) ==========
AZURE__OPENAI__ENDPOINT=https://your-resource.openai.azure.com/
AZURE__OPENAI__KEY=your-azure-openai-key

# ========== DATABASE CONNECTION ==========
ConnectionStrings__DefaultConnection=Server=.;Database=JifasAssistant;Trusted_Connection=true;Encrypt=false

# ========== QDRANT VECTOR DATABASE ==========
QDRANT__ENABLED=true
QDRANT__URL=http://localhost:6333
QDRANT__COLLECTIONNAME=jifas_kb
QDRANT__APIKEY=your-secure-qdrant-api-key
QDRANT__EMBEDDINGDIMENSIONS=384

# ========== SUPPORT SETTINGS ==========
SUPPORT__HELPDESKEMAIL=it@jababeka.com
SUPPORT__HELPDESKPHONE=+62-21-XXXX-XXXX
SUPPORT__DEPARTMENT=IT Help Desk

# ========== CACHING ==========
CACHING__DEFAULTDURATIONMINUTES=30
CACHING__RESPONSEDURATIONHOURS=24
CACHING__ENABLEKBCACHE=true
CACHING__ENABLERESPONSECACHE=true

# ========== PERFORMANCE MONITORING ==========
PERFORMANCE__ENABLEMONITORING=true
PERFORMANCE__SLOWOPERATIONTHRESHOLDMS=1000
PERFORMANCE__MAXCACHESIZE=10000
PERFORMANCE__ENABLECOMPRESSIONRESPONSE=true

# ========== LOGGING ==========
LOGGING__LOGLEVEL__DEFAULT=Information
LOGGING__LOGFILEPATH=Logs/jifas-chatbot-{Date}.log

# ========== ASPNETCORE ENVIRONMENT ==========
# Options: Development, Production, Staging
ASPNETCORE_ENVIRONMENT=Development
