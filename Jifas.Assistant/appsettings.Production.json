{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_PRODUCTION_SERVER;Database=JifasAssistant;User Id=sa;Password=YOUR_PASSWORD;Encrypt=true;TrustServerCertificate=false"
  },

  "Ollama": {
    "BaseUrl": "http://10.0.12.54:11434",
    "Model": "qwen3:8b",
    "Temperature": 0.3,
    "MaxTokens": 2048,
    "TimeoutSeconds": 180
  }",
    "Model": "gemini-2.0-flash",
    "BaseUrl": "https://generativelanguage.googleapis.com/v1beta/models"
  },

  "Qdrant": {
    "Enabled": true,
    "Url": "http://qdrant-production:6333",
    "CollectionName": "jifas_kb",
    "ApiKey": "${QDRANT_API_KEY}",
    "EmbeddingDimensions": 384
  },

  "Performance": {
    "EnableMonitoring": true,
    "SlowOperationThresholdMs": 500,
    "MaxCacheSize": 50000,
    "EnableCompressionResponse": true,
    "CompressionThresholdBytes": 512
  }
}


